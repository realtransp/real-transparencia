# Local: deixe vazio para usar SQLite (resumo_real.db).
# Railway: cole a connection string do plugin Postgres.
DATABASE_URL=

# Chave da API do Grok (xAI). Sem ela, a app funciona mas não gera resumos.
XAI_API_KEY=
XAI_MODEL=grok-4

# Subsídio mensal bruto do deputado (valor fixo).
SUBSIDIO_MENSAL=46366.19
